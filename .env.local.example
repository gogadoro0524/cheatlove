# ── Copy to .env.local and fill in. NEVER commit .env.local. ──

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...            # "anon / public" key — safe for the browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...                # "service_role" key — SERVER ONLY, bypasses RLS, never expose

# Stripe (Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=sk_test_...                   # use sk_test_ while validating
STRIPE_WEBHOOK_SECRET=whsec_...                 # from the webhook endpoint you register

# Telegram alerts (BotFather token + your chat id)
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=123456789

# Admin access — comma-separated emails granted the "admin" role.
# Admins see the internal demo pages (/scan-demo, /report-demo) + their nav links.
# (Or set app_metadata.role = "admin" on the Supabase user instead.)
ADMIN_EMAILS=you@example.com,teammate@example.com
